// chunk.src — Chunk model + ingest pipeline (detect → parse → normalize → upsert).

type Chunk struct {
    text string
    meta string
}

// UTF-8 boundary helpers — MFL len/substr are byte-based; mid-codepoint cuts
// produce invalid JSON that Qdrant rejects ("invalid unicode code point").
func utf8_is_cont(b) (y) {
    y = 0
    if b >= 128 {
        if b < 192 { y = 1 }
    }
}

func utf8_floor(s, i) (out) {
    raw := bytes(s)
    n := len(raw)
    if i <= 0 { out = 0; return }
    if i >= n { out = n; return }
    out = i
    while out > 0 {
        if utf8_is_cont(byte_at(raw, out)) == 1 {
            out = out - 1
            continue
        }
        break
    }
}

func utf8_ceil(s, i) (out) {
    raw := bytes(s)
    n := len(raw)
    if i <= 0 { out = 0; return }
    if i >= n { out = n; return }
    out = i
    while out < n {
        if utf8_is_cont(byte_at(raw, out)) == 1 {
            out = out + 1
            continue
        }
        break
    }
}

func safe_substr(s, start, end) (out) {
    raw := bytes(s)
    n := len(raw)
    if start < 0 { start = 0 }
    if end > n { end = n }
    start = utf8_ceil(s, start)
    end = utf8_floor(s, end)
    if start > end { start = end }
    out = substr(s, start, end)
}

func chunk_make(text, meta) (c) {
    c = Chunk{text: text, meta: meta}
}

func ext_of(path) (e) {
    e = ""
    i := len(path) - 1
    while i >= 0 {
        ch := substr(path, i, i + 1)
        if ch == "/" { break }
        if ch == "." {
            e = to_lower(substr(path, i + 1, len(path)))
            break
        }
        i = i - 1
    }
}

func detect_format(path, override) (fmt) {
    fmt = to_lower(override)
    if fmt != "" { return }
    pl := to_lower(path)
    // Phase 0 vision: foo.jpg.md / foo.png.txt → image-caption
    if has_suffix(pl, ".jpg.md") || has_suffix(pl, ".jpeg.md") || has_suffix(pl, ".png.md") || has_suffix(pl, ".webp.md") {
        fmt = "image-caption"
        return
    }
    if has_suffix(pl, ".jpg.txt") || has_suffix(pl, ".jpeg.txt") || has_suffix(pl, ".png.txt") || has_suffix(pl, ".webp.txt") {
        fmt = "image-caption"
        return
    }
    fmt = ext_of(path)
    if fmt == "markdown" { fmt = "md" }
    if fmt == "txt" { fmt = "md" }
    if fmt == "jpeg" { fmt = "jpg" }
    if fmt == "" { fmt = "txt" }
}

func is_image_format(fmt) (y) {
    y = 0
    if fmt == "jpg" || fmt == "png" || fmt == "webp" || fmt == "gif" { y = 1 }
}

func image_path_from_sidecar(path) (img) {
    pl := to_lower(path)
    img = path
    if has_suffix(pl, ".md") { img = substr(path, 0, len(path) - 3); return }
    if has_suffix(pl, ".txt") { img = substr(path, 0, len(path) - 4); return }
}

func find_image_sidecar(path) (side) {
    side = ""
    c1 := path + ".md"
    if read_file(c1) != "" { side = c1; return }
    c2 := path + ".txt"
    if read_file(c2) != "" { side = c2; return }
    // path/foo.jpg → path/foo.md
    ext := ext_of(path)
    if ext == "" { return }
    base := substr(path, 0, len(path) - len(ext) - 1)
    c3 := base + ".md"
    if read_file(c3) != "" { side = c3; return }
    c4 := base + ".txt"
    if read_file(c4) != "" { side = c4; return }
}

// Phase 0: caption text → chunk with payload.image (no LLM, no pixels).
func ingest_image_caption_text(coll, text, image_path, source) (ok, detail) {
    if trim(text) == "" {
        ok = 0
        detail = "empty image caption for " + image_path
        return
    }
    meta := "{\"source\":\"" + jesc(source) + "\",\"format\":\"image-caption\",\"image\":\"" + jesc(image_path) + "\",\"vision\":\"sidecar\"}"
    // Prefer md sectioning when caption has headings; else one chunk.
    chunks := parse_md(text, source)
    if len(chunks) == 0 {
        chunks = []Chunk{}
        chunks = append(chunks, chunk_make(trim(text), meta))
    } else {
        // stamp image onto each chunk meta
        stamped := []Chunk{}
        for _, c := range chunks {
            m := c.meta
            if m == "" { m = "{}" }
            if has_suffix(m, "}") {
                m = substr(m, 0, len(m) - 1) + ",\"image\":\"" + jesc(image_path) + "\",\"vision\":\"sidecar\",\"format\":\"image-caption\"}"
            }
            stamped = append(stamped, chunk_make(c.text, m))
        }
        chunks = stamped
    }
    ok, detail = upsert_chunks(coll, chunks)
}

// Path/folder/filename → searchable text without LLM or OCR.
func image_path_caption(path) (text) {
    base := path_basename(path)
    parent := path_parent_name(path)
    stem := base
    ext := ext_of(base)
    if ext != "" {
        if len(base) > len(ext) + 1 {
            stem = substr(base, 0, len(base) - len(ext) - 1)
        }
    }
    text = "[image] " + path + "\n"
    if parent != "" { text = text + "dossier: " + parent + "\n" }
    text = text + "fichier: " + stem + "\n"
    if parent != "" { text = text + parent + " — " + stem }
    else { text = text + stem }
}

func path_parent_name(path) (name) {
    name = ""
    end := len(path) - 1
    while end >= 0 {
        if substr(path, end, end + 1) == "/" { break }
        end = end - 1
    }
    if end <= 0 { return }
    dir := substr(path, 0, end)
    name = path_basename(dir)
}

// Phase 0 sidecar → Phase 1 OCR → Phase 0b path taxonomy (no LLM).
func ingest_image_file(coll, path) (ok, detail) {
    side := find_image_sidecar(path)
    if side != "" {
        raw := read_file(side)
        ok, detail = ingest_image_caption_text(coll, raw, path, side)
        return
    }
    // Phase 1 — local Tesseract when enabled
    if cfg_ocr_enabled() == 1 {
        if ocr_available() == 1 {
            ook, otext := ocr_file(path)
            if ook == 1 {
                otext = trim(otext)
                if otext != "" {
                    body := "[image] " + path + "\n" + otext
                    meta := "{\"source\":\"" + jesc(path) + "\",\"format\":\"image-ocr\",\"image\":\"" + jesc(path) + "\",\"vision\":\"ocr\"}"
                    cs := []Chunk{}
                    cs = append(cs, chunk_make(body, meta))
                    ok, detail = upsert_chunks(coll, cs)
                    return
                }
            }
        }
    }
    // Phase 0b — folder + filename are enough for many landing assets
    body := image_path_caption(path)
    meta := "{\"source\":\"" + jesc(path) + "\",\"format\":\"image-path\",\"image\":\"" + jesc(path) + "\",\"vision\":\"path\"}"
    cs := []Chunk{}
    cs = append(cs, chunk_make(body, meta))
    ok, detail = upsert_chunks(coll, cs)
}

func join_path(dir, name) (p) {
    if has_suffix(dir, "/") {
        p = dir + name
    } else {
        p = dir + "/" + name
    }
}

// Folder walk: ingest images under dir (depth≤2). Returns image count (not dir count).
func ingest_dir(coll, dir, depth) (ok, detail, n) {
    n = 0
    if depth > 2 {
        ok = 1
        detail = "{\"skipped_deep\":true}"
        return
    }
    entries := list_dir(dir)
    errs := 0
    last := ""
    for _, name := range entries {
        if name == "" { continue }
        if has_prefix(name, ".") { continue }
        // skip sidecar files themselves (ingested via the image)
        nl := to_lower(name)
        if has_suffix(nl, ".jpg.md") || has_suffix(nl, ".jpeg.md") || has_suffix(nl, ".png.md") || has_suffix(nl, ".webp.md") { continue }
        if has_suffix(nl, ".jpg.txt") || has_suffix(nl, ".png.txt") { continue }
        full := join_path(dir, name)
        ext := ext_of(full)
        if ext == "jpeg" { ext = "jpg" }
        if is_image_format(ext) == 1 {
            iok, idet := ingest_image_file(coll, full)
            if iok == 0 {
                errs = errs + 1
                last = idet
            } else {
                n = n + 1
            }
            continue
        }
        if path_looks_like_dir(full) == 1 {
            sok, sdet, sn := ingest_dir(coll, full, depth + 1)
            if sok == 0 {
                errs = errs + 1
                last = sdet
            } else {
                n = n + sn
            }
        }
    }
    if n == 0 {
        if errs > 0 {
            ok = 0
            detail = last
            return
        }
        ok = 0
        detail = "no images found under " + dir
        return
    }
    ok = 1
    detail = "{\"dir\":\"" + jesc(dir) + "\",\"images\":" + str(n) + ",\"errors\":" + str(errs) + "}"
}

func path_looks_like_dir(path) (y) {
    y = 0
    if has_suffix(path, "/") { y = 1; return }
    // file with a known extension → not a dir
    ext := ext_of(path)
    if ext == "md" || ext == "txt" || ext == "csv" || ext == "json" || ext == "ndjson" || ext == "docx" || ext == "pdf" { return }
    if is_image_format(ext) == 1 { return }
    if ext == "jpeg" { return }
    // directory if list_dir yields entries (or empty dir with no ext)
    entries := list_dir(path)
    if len(entries) > 0 { y = 1; return }
    if ext == "" { y = 1 }
}

// Apply declarative normalize.template using {{key}} from meta JSON + {{text}}.
func normalize_chunk(c) (out) {
    out = c
    tmpl := cfg_normalize_template()
    if tmpl == "" { return }
    s := tmpl
    s = replace(s, "{{text}}", c.text)
    // Replace {{key}} for a few common keys from meta via json_get
    keys := []string{"title", "heading", "id", "source", "format", "row", "name", "body", "content"}
    for _, k := range keys {
        raw, err := json_get(c.meta, "." + k)
        if err == "" {
            s = replace(s, "{{" + k + "}}", cfg_unquote(raw))
        }
    }
    out.text = s
}

func drop_empty_chunk(c) (keep) {
    keep = 1
    if cfg_normalize_drop_empty() == 1 {
        if trim(c.text) == "" { keep = 0 }
    }
}

func parse_to_chunks(fmt, raw, source) (chunks) {
    chunks = []Chunk{}
    if fmt == "md" || fmt == "txt" {
        chunks = parse_md(raw, source)
        return
    }
    if fmt == "csv" {
        chunks = parse_csv(raw, source)
        return
    }
    if fmt == "json" || fmt == "ndjson" {
        chunks = parse_json(raw, source, fmt)
        return
    }
    // fallback: whole file as one chunk
    meta := "{\"source\":\"" + jesc(source) + "\",\"format\":\"" + jesc(fmt) + "\"}"
    chunks = append(chunks, chunk_make(raw, meta))
}

func ingest_text(coll, text, source, fmt) (ok, detail) {
    if fmt == "" { fmt = "txt" }
    chunks := parse_to_chunks(fmt, text, source)
    // normalize + filter
    kept := []Chunk{}
    for _, c := range chunks {
        c2 := normalize_chunk(c)
        if drop_empty_chunk(c2) == 1 {
            kept = append(kept, c2)
        }
    }
    if len(kept) == 0 {
        ok = 0
        detail = "no chunks after parse/normalize"
        return
    }
    ok, detail = upsert_chunks(coll, kept)
}

func ingest_file(coll, path, fmt_override) (ok, detail) {
    if path_looks_like_dir(path) == 1 {
        ok, detail, _ = ingest_dir(coll, path, 0)
        return
    }
    fmt := detect_format(path, fmt_override)
    if fmt == "docx" {
        ok, detail = ingest_docx(coll, path)
        return
    }
    if fmt == "pdf" {
        ok, detail = ingest_pdf(coll, path)
        return
    }
    if fmt == "image-caption" {
        raw := read_file(path)
        if raw == "" {
            ok = 0
            detail = "empty or missing file: " + path
            return
        }
        img := image_path_from_sidecar(path)
        ok, detail = ingest_image_caption_text(coll, raw, img, path)
        return
    }
    if is_image_format(fmt) == 1 {
        ok, detail = ingest_image_file(coll, path)
        return
    }
    raw := read_file(path)
    if raw == "" {
        ok = 0
        detail = "empty or missing file: " + path
        return
    }
    ok, detail = ingest_text(coll, raw, path, fmt)
}
